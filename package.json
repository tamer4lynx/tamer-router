{
  "name": "@tamer4lynx/tamer-router",
  "version": "0.0.10",
  "publishConfig": { "access": "public", "tag": "prerelease" },
  "type": "module",
  "description": "File-based routing for Lynx with TanStack Router. Rsbuild plugin + memory routing.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./layouts": {
      "types": "./dist/src/layouts.d.ts",
      "import": "./dist/src/layouts.js",
      "default": "./dist/src/layouts.js"
    },
    "./plugin": {
      "types": "./dist/src/plugin.d.ts",
      "import": "./dist/src/plugin.js",
      "default": "./dist/src/plugin.js"
    },
    "./tamer.config": {
      "types": "./dist/tamer.config.d.ts",
      "import": "./dist/tamer.config.js",
      "default": "./dist/tamer.config.js"
    },
    "./generated-routes": {
      "types": "./dist/src/generated-routes.d.ts",
      "import": "./dist/src/generated-routes.js",
      "default": "./dist/src/generated-routes.js"
    }
  },
  "files": [
    "dist",
    "android/src",
    "android/build.gradle.kts",
    "ios",
    "lynx.ext.json"
  ],
  "lynx": {
    "ext": "lynx.ext.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && cp src/tamer-router.css dist/src/tamer-router.css"
  },
  "peerDependencies": {
    "react": "^17.0.0"
  },
  "dependencies": {
    "@rsbuild/core": "^1.3.0",
    "@tanstack/history": "1.15.13",
    "@tanstack/react-router": "1.20.0",
    "chokidar": "^4.0.0",
    "@tamer4lynx/tamer-app-shell": "^0.0.5",
    "url-search-params-polyfill": "^8.2.5"
  },
  "devDependencies": {
    "@types/react": "^17.0.0",
    "react": "^17.0.2",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tamer4lynx/tamer-router.git"
  },
  "homepage": "https://github.com/tamer4lynx/tamer-router#readme",
  "bugs": {
    "url": "https://github.com/tamer4lynx/tamer-router/issues"
  },
  "author": "Nanofuxion",
  "license": "MIT"
}
