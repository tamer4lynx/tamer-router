{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "preserve",
    "jsxImportSource": "@lynx-js/react",
    "noEmit": false,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@tamer4lynx/tamer-app-shell": [
        "../tamer-app-shell/dist/src/index.d.ts"
      ]
    }
  },
  "include": ["src/**/*", "tamer.config.ts"],
  "exclude": ["node_modules", "dist"]
}
