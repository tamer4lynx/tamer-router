{
  "name": "tamer-router",
  "version": "0.1.0",
  "type": "module",
  "description": "File-based routing for Lynx (React 17 + react-router 6). Rsbuild plugin + MemoryRouter.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./plugin": {
      "types": "./dist/src/plugin.d.ts",
      "import": "./dist/src/plugin.js",
      "default": "./dist/src/plugin.js"
    },
    "./tamer.config": {
      "types": "./dist/tamer.config.d.ts",
      "import": "./dist/tamer.config.js",
      "default": "./dist/tamer.config.js"
    }
  },
  "files": ["dist", "android", "lynx.ext.json"],
  "lynx": { "ext": "lynx.ext.json" },
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "react": "^17.0.0",
    "react-router": "^6.0.0"
  },
  "dependencies": {
    "@rsbuild/core": "^1.3.0",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^17.0.0",
    "react": "^17.0.2",
    "react-router": "^6.28.0",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Nanofuxion",
  "license": "MIT"
}
